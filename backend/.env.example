# Server
PORT=3000
CORS_ORIGIN=chrome-extension://*
NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-random-secret

# AI Provider: openrouter | deepseek | auto
AI_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# DeepSeek (direct)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Database (SQLite)
DATABASE_URL=file:./data/textflow.db

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_PRO_PLUS_PRICE_ID=price_pro_plus_monthly

# Stripe (production mode)
# STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# STRIPE_PRO_PRICE_ID=price_pro_monthly_live
# STRIPE_PRO_PLUS_PRICE_ID=price_pro_plus_monthly_live
#
# To switch to production:
# 1. Replace sk_test_ with sk_live_ keys above
# 2. Update price IDs from Stripe Dashboard > Products > Pricing
