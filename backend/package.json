    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.104.0",
    "stripe": "^17.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.9",
    "drizzle-kit": "^0.31.10",
